# OBT Mentor Companion - Environment Variables
# Copy this file to .env and fill in the values

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Google Cloud
GOOGLE_API_KEY=your_gemini_api_key

# Qdrant Vector Database
QDRANT_URL=https://your-qdrant-instance.cloud.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key

# Session
SESSION_SECRET=generate_a_random_32_character_minimum_string

# Node Environment
NODE_ENV=development

# GCP Secrets (for Docker Compose)
# These are used by the gcp-secrets service to fetch secrets from GCP Secret Manager
SECRETS_PROJECT_ID=shemaobt-secrets
